{
  "name": "dotenvify",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "packages/*",
    "cli",
    "landing"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:landing": "turbo run dev --filter=@dotenvify/site",
    "dev:cli": "turbo run dev --filter=@webbies.dev/dotenvify"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.8.0"
  }
}

{
  "name": "dotenvify",
  "private": true,
  "workspaces": [
    "packages/*",
    "cli",
    "plugins/vscode",
    "site"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:site": "npm run dev --workspace=site",
    "dev:cli": "npm run dev --workspace=cli"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.8.0"
  }
}
